{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "exeoutput-studio",
    "version": "../package.json"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "fs": {
        "all": true,
        "scope": ["$APPDIR/*", "$DOCUMENT/*", "$RESOURCE/*"]
      },
      "path": {
        "all": true
      },
      "shell": {
        "all": true,
        "open": true
      },
      "dialog": {
        "all": true
      },
      "process": {
        "all": true
      },
      "window": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "targets": ["msi", "nsis", "updater"],
      "identifier": "com.exeoutput.studio",
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
      "publisher": "ExeOutput"
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://ben-sms.com/maj.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERDRDQxNzU5NTc0QjY0QTUKUldTbFpFdFhXUmZVM0F4eVMvMzVJS1RPNitDZndENmROTE43Q2NmOEhSbForUC9vS09LOWhCamMK"
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "resizable": true,
        "title": "ExeOutput Studio",
        "width": 1440,
        "maximized": true
      }
    ]
  }
}
